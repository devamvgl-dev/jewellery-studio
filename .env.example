# ============================================================
#  Design Innovation Studio - environment variables
#
#  Copy this file to ".env" and paste your real keys:
#      copy .env.example .env        (Windows)
#
#  ".env" is gitignored and must NEVER be committed or shared.
#  On Render, do NOT upload .env - set these same variables in
#  the dashboard under  Settings -> Environment  instead.
# ============================================================

# Anthropic (Claude) API key - https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-your-key-here

# fal.ai API key for FLUX image generation - https://fal.ai/dashboard/keys
FAL_KEY=your-fal-key-here

# ── Login / authentication ──────────────────────────────────
# Secret used to sign session cookies. Use a long random string.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Fixed user accounts, as comma-separated  username:password  pairs.
# Example below defines three logins. Use strong passwords in production.
APP_USERS=amit:changeme1,priya:changeme2,studio:changeme3
